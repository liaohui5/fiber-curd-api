    "definitions": {
        "fmtres.FormatResponse": {
            "type": "object",
            "properties": {
                "message": {
                    "description": "操作附带消息",
                    "type": "string"
                },
                "results": {
                    "description": "操作附带数据"
                },
                "success": {
                    "description": "操作是否成功",
                    "type": "boolean"
                }
            }
        },
        "handlers.LoginDTO": {
            "type": "object",
            "properties": {
                "email": {
                    "description": "邮箱",
                    "type": "string"
                },
                "password": {
                    "description": "密码md5",
                    "type": "string"
                }
            }
        },
        "handlers.LoginRes": {
            "type": "object",
            "properties": {
                "access_token": {
                    "description": "访问token",
                    "type": "string"
                },
                "refresh_token": {
                    "description": "刷新token",
                    "type": "string"
                },
                "user": {
                    "description": "用户信息",
                    "allOf": [
                        {
                            "$ref": "#/definitions/models.User"
                        }
                    ]
                }
            }
        },
        "handlers.RegisterDTO": {
            "type": "object",
            "required": [
                "email",
                "password"
            ],
            "properties": {
                "email": {
                    "description": "用户邮箱",
                    "type": "string"
                },
                "password": {
                    "description": "用户密码md5(避免明文传输)",
                    "type": "string"
                },
                "username": {
                    "description": "用户名(可选)",
                    "type": "string"
                }
            }
        },
        "handlers.RenewAccessTokenRes": {
            "type": "object",
            "properties": {
                "access_token": {
                    "description": "访问token",
                    "type": "string"
                },
                "refresh_token": {
                    "description": "刷新token",
                    "type": "string"
                }
            }
        },
        "models.Article": {
            "type": "object",
            "required": [
                "contents",
                "title",
                "user_id"
            ],
            "properties": {
                "author": {
                    "description": "文章作者信息",
