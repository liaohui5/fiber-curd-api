                    "description": "文章内容",
                    "type": "string"
                },
                "created_at": {
                    "description": "创建时间",
                    "type": "string"
                },
                "id": {
                    "description": "主键ID",
                    "type": "integer"
                },
                "likes": {
                    "description": "点赞数",
                    "type": "integer"
                },
                "shares": {
                    "description": "转发(分享)数",
                    "type": "integer"
                },
                "stars": {
                    "description": "收藏数",
                    "type": "integer"
                },
                "title": {
                    "description": "文章标题",
                    "type": "string"
                },
                "updated_at": {
                    "description": "更新时间",
                    "type": "string"
                },
                "user_id": {
                    "description": "作者ID",
                    "type": "integer"
                }
            }
        },
        "models.Task": {
            "type": "object",
            "required": [
                "meta_data",
